@page "/login"
@using AuntiesCleaners.Client.Models
@using AuntiesCleaners.Client.Services
@using AuntiesCleaners.Client.Shared
@inject IAuthService AuthService
@inject ITabConfigService TabConfigService
@inject NavigationManager Navigation

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center" Style="min-height: 80vh;">
    <MudPaper Elevation="3" Class="pa-8 mx-auto" Style="width: 100%; max-width: 400px;">
        <MudStack Spacing="4" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.h4" Color="Color.Primary">Auntie's Cleaners</MudText>
            <MudText Typo="Typo.subtitle1" Color="Color.Secondary">Sign in to continue</MudText>

            <MudTextField @bind-Value="_email"
                          Label="Email"
                          Variant="Variant.Outlined"
                          InputType="InputType.Email"
                          FullWidth="true"
                          Immediate="true"
                          autocomplete="email" />

            <MudTextField @bind-Value="_password"
                          Label="Password"
                          Variant="Variant.Outlined"
                          InputType="InputType.Password"
                          FullWidth="true"
                          Immediate="true"
                          autocomplete="current-password"
                          OnKeyDown="HandleKeyDown" />

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Dense="true">@_errorMessage</MudAlert>
            }

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       Disabled="_isLoading"
                       OnClick="HandleLogin">
                @if (_isLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Sign In
            </MudButton>
        </MudStack>
    </MudPaper>
</MudContainer>

@code {
    private string _email = string.Empty;
    private string _password = string.Empty;
    private string _errorMessage = string.Empty;
    private bool _isLoading;

    protected override async Task OnInitializedAsync()
    {
        if (AuthService.IsAuthenticated)
        {
            var route = await GetFirstTabRouteAsync();
            Navigation.NavigateTo(route);
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await HandleLogin();
    }

    private async Task HandleLogin()
    {
        _errorMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
        {
            _errorMessage = "Please enter your email and password.";
            return;
        }

        _isLoading = true;
        try
        {
            var success = await AuthService.LoginAsync(_email, _password);
            if (success)
            {
                var route = await GetFirstTabRouteAsync();
                Navigation.NavigateTo(route);
            }
            else
            {
                _errorMessage = "Invalid email or password.";
            }
        }
        catch
        {
            _errorMessage = "An error occurred. Please try again.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task<string> GetFirstTabRouteAsync()
    {
        var profileId = await AuthService.GetCurrentUserProfileIdAsync();
        if (profileId.HasValue)
        {
            var saved = await TabConfigService.GetTabsForUserAsync(profileId.Value);
            var firstVisible = saved
                .Where(t => t.IsVisible && AllTabs.ByName.ContainsKey(t.TabName))
                .OrderBy(t => t.DisplayOrder)
                .FirstOrDefault();

            if (firstVisible != null)
                return AllTabs.ByName[firstVisible.TabName].Route;
        }

        return "cleaning";
    }
}
