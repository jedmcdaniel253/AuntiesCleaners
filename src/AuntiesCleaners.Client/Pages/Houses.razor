@page "/houses"
@using AuntiesCleaners.Client.Models
@using AuntiesCleaners.Client.Services
@using AuntiesCleaners.Client.Shared
@inject IHouseService HouseService
@inject IOwnerService OwnerService
@inject ISnackbar Snackbar

<RoleGuard AllowedRoles="@(new[] { Role.Boss, Role.Admin })">
    <MudText Typo="Typo.h5" Class="mb-4">Houses</MudText>

    <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mb-4" OnClick="ShowAddForm">
        Add House
    </MudButton>

    @if (_showForm)
    {
        <MudPaper Class="pa-4 mb-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-2">@(_editingHouse?.Id != Guid.Empty ? "Edit" : "Add") House</MudText>
            <MudTextField @bind-Value="_formName" Label="Name / Address" Variant="Variant.Outlined" Class="mb-2" />
            <MudSelect T="Guid?" @bind-Value="_formOwnerId" Label="Owner" Variant="Variant.Outlined" Class="mb-2" Clearable="true">
                @foreach (var owner in _owners)
                {
                    <MudSelectItem T="Guid?" Value="@owner.Id">@owner.Name</MudSelectItem>
                }
            </MudSelect>
            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveHouse">Save</MudButton>
                <MudButton Variant="Variant.Text" OnClick="@(() => _showForm = false)">Cancel</MudButton>
            </MudStack>
        </MudPaper>
    }

    <MudTable Items="_houses" Hover="true" Dense="true">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Owner</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                @context.Name
                @if (context.IsMultipleHouses)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Class="ml-2">System</MudChip>
                }
            </MudTd>
            <MudTd>@GetOwnerName(context.OwnerId)</MudTd>
            <MudTd>
                <MudChip T="string" Color="@(context.IsActive ? Color.Success : Color.Default)" Size="Size.Small">
                    @(context.IsActive ? "Active" : "Inactive")
                </MudChip>
            </MudTd>
            <MudTd>
                @if (!context.IsMultipleHouses)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => EditHouse(context))" />
                    @if (context.IsActive)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                       OnClick="@(() => DeactivateHouse(context))" />
                    }
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
</RoleGuard>

@code {
    private List<House> _houses = new();
    private List<Owner> _owners = new();
    private bool _showForm;
    private House? _editingHouse;
    private string _formName = string.Empty;
    private Guid? _formOwnerId;

    protected override async Task OnInitializedAsync()
    {
        await LoadHouses();
        _owners = await OwnerService.GetAllAsync();
    }

    private async Task LoadHouses()
    {
        _houses = await HouseService.GetAllAsync();
    }

    private void ShowAddForm()
    {
        _editingHouse = new House();
        _formName = string.Empty;
        _formOwnerId = null;
        _showForm = true;
    }

    private void EditHouse(House house)
    {
        _editingHouse = house;
        _formName = house.Name;
        _formOwnerId = house.OwnerId;
        _showForm = true;
    }

    private async Task SaveHouse()
    {
        if (string.IsNullOrWhiteSpace(_formName))
        {
            Snackbar.Add("Name is required.", Severity.Error);
            return;
        }

        _editingHouse!.Name = _formName;
        _editingHouse.OwnerId = _formOwnerId;

        if (_editingHouse.Id == Guid.Empty)
        {
            await HouseService.CreateAsync(_editingHouse);
            Snackbar.Add("House added.", Severity.Success);
        }
        else
        {
            await HouseService.UpdateAsync(_editingHouse);
            Snackbar.Add("House updated.", Severity.Success);
        }

        _showForm = false;
        await LoadHouses();
    }

    private async Task DeactivateHouse(House house)
    {
        await HouseService.DeactivateAsync(house.Id);
        Snackbar.Add($"{house.Name} deactivated.", Severity.Info);
        await LoadHouses();
    }

    private string GetOwnerName(Guid? ownerId) =>
        _owners.FirstOrDefault(o => o.Id == ownerId)?.Name ?? "";
}
