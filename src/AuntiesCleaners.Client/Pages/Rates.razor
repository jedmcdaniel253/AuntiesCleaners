@page "/rates"
@using AuntiesCleaners.Client.Models
@using AuntiesCleaners.Client.Services
@using AuntiesCleaners.Client.Shared
@inject IRateService RateService
@inject IWorkerService WorkerService
@inject IHouseService HouseService
@inject ISnackbar Snackbar

<RoleGuard AllowedRoles="@(new[] { Role.Boss, Role.Admin })">
    <MudText Typo="Typo.h5" Class="mb-4">Rates</MudText>

    <MudExpansionPanels MultiExpansion="true">
        @* Section 1: Cleaning & Maintenance Hourly Rates *@
        <MudExpansionPanel Text="Cleaning / Maintenance Hourly Rates" IsInitiallyExpanded="true">
            @foreach (var category in new[] { "Cleaning", "Maintenance" })
            {
                var defaultRate = GetDefaultRate(category);
                <MudText Typo="Typo.h6" Class="mb-2 mt-4">@category</MudText>
                <MudPaper Class="pa-3 mb-3" Elevation="1">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Default Rate</MudText>
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudNumericField T="decimal" Label="Rate Charged ($/hr)" Min="0.01M"
                                         Value="@(defaultRate?.RateCharged ?? 0)"
                                         ValueChanged="@(v => OnDefaultRateChanged(category, v, defaultRate?.RatePaid ?? 0))"
                                         Variant="Variant.Outlined" Style="max-width:180px" />
                        <MudNumericField T="decimal" Label="Rate Paid ($/hr)" Min="0M"
                                         Value="@(defaultRate?.RatePaid ?? 0)"
                                         ValueChanged="@(v => OnDefaultRateChanged(category, defaultRate?.RateCharged ?? 0, v))"
                                         Variant="Variant.Outlined" Style="max-width:180px" />
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                   OnClick="@(() => SaveDefaultRate(category))">Save</MudButton>
                    </MudStack>
                </MudPaper>

                <MudText Typo="Typo.subtitle2" Class="mb-2">Per-Worker Overrides</MudText>
                <MudTable Items="@GetWorkerRates(category)" Hover="true" Dense="true" Class="mb-3">
                    <HeaderContent>
                        <MudTh>Worker</MudTh>
                        <MudTh>Rate Charged ($/hr)</MudTh>
                        <MudTh>Rate Paid ($/hr)</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@GetWorkerName(context.WorkerId)</MudTd>
                        <MudTd>@context.RateCharged.ToString("F2")</MudTd>
                        <MudTd>@context.RatePaid.ToString("F2")</MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           OnClick="@(() => EditWorkerRate(context))" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" Class="mb-4"
                           OnClick="@(() => ShowAddWorkerRate(category))">Add Worker Override</MudButton>
            }
        </MudExpansionPanel>

        @* Section 2: Laundry Per-Load Rates *@
        <MudExpansionPanel Text="Laundry Per-Load Rates">
            <MudPaper Class="pa-3 mb-3" Elevation="1">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Default Rate</MudText>
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                    <MudNumericField T="decimal" Label="Rate Charged ($/load)" Min="0.01M"
                                     Value="@(GetDefaultRate("Laundry")?.RateCharged ?? 0)"
                                     ValueChanged="@(v => OnDefaultRateChanged("Laundry", v, GetDefaultRate("Laundry")?.RatePaid ?? 0))"
                                     Variant="Variant.Outlined" Style="max-width:180px" />
                    <MudNumericField T="decimal" Label="Rate Paid ($/load)" Min="0M"
                                     Value="@(GetDefaultRate("Laundry")?.RatePaid ?? 0)"
                                     ValueChanged="@(v => OnDefaultRateChanged("Laundry", GetDefaultRate("Laundry")?.RateCharged ?? 0, v))"
                                     Variant="Variant.Outlined" Style="max-width:180px" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                               OnClick="@(() => SaveDefaultRate("Laundry"))">Save</MudButton>
                </MudStack>
            </MudPaper>

            <MudText Typo="Typo.subtitle2" Class="mb-2">Per-Worker Overrides</MudText>
            <MudTable Items="@GetWorkerRates("Laundry")" Hover="true" Dense="true" Class="mb-3">
                <HeaderContent>
                    <MudTh>Worker</MudTh>
                    <MudTh>Rate Charged ($/load)</MudTh>
                    <MudTh>Rate Paid ($/load)</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@GetWorkerName(context.WorkerId)</MudTd>
                    <MudTd>@context.RateCharged.ToString("F2")</MudTd>
                    <MudTd>@context.RatePaid.ToString("F2")</MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       OnClick="@(() => EditWorkerRate(context))" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" Class="mb-4"
                       OnClick="@(() => ShowAddWorkerRate("Laundry"))">Add Worker Override</MudButton>
        </MudExpansionPanel>

        @* Section 3: Lawn Per-House Flat Rates *@
        <MudExpansionPanel Text="Lawn Per-House Flat Rates">
            @foreach (var house in _houses.Where(h => !h.IsMultipleHouses))
            {
                var lawnDefault = GetDefaultLawnRate(house.Id);
                <MudText Typo="Typo.h6" Class="mb-2 mt-4">@house.Name</MudText>
                <MudPaper Class="pa-3 mb-3" Elevation="1">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Default Rate</MudText>
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudNumericField T="decimal" Label="Rate Charged ($)" Min="0.01M"
                                         Value="@(lawnDefault?.RateCharged ?? 0)"
                                         ValueChanged="@(v => OnDefaultLawnRateChanged(house.Id, v, lawnDefault?.RatePaid ?? 0))"
                                         Variant="Variant.Outlined" Style="max-width:180px" />
                        <MudNumericField T="decimal" Label="Rate Paid ($)" Min="0M"
                                         Value="@(lawnDefault?.RatePaid ?? 0)"
                                         ValueChanged="@(v => OnDefaultLawnRateChanged(house.Id, lawnDefault?.RateCharged ?? 0, v))"
                                         Variant="Variant.Outlined" Style="max-width:180px" />
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                   OnClick="@(() => SaveDefaultLawnRate(house.Id))">Save</MudButton>
                    </MudStack>
                </MudPaper>

                <MudText Typo="Typo.subtitle2" Class="mb-2">Per-Worker Overrides</MudText>
                <MudTable Items="@GetWorkerLawnRates(house.Id)" Hover="true" Dense="true" Class="mb-3">
                    <HeaderContent>
                        <MudTh>Worker</MudTh>
                        <MudTh>Rate Charged ($)</MudTh>
                        <MudTh>Rate Paid ($)</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@GetWorkerName(context.WorkerId)</MudTd>
                        <MudTd>@context.RateCharged.ToString("F2")</MudTd>
                        <MudTd>@context.RatePaid.ToString("F2")</MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           OnClick="@(() => EditWorkerLawnRate(context))" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" Class="mb-4"
                           OnClick="@(() => ShowAddWorkerLawnRate(house.Id))">Add Worker Override</MudButton>
            }
        </MudExpansionPanel>
    </MudExpansionPanels>

    @* Rate edit/add form *@
    @if (_showRateForm)
    {
        <MudPaper Class="pa-4 mt-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-2">@(_editingRate?.Id != Guid.Empty ? "Edit" : "Add") Rate — @_editingCategory</MudText>
            @if (_editingRate?.Id == Guid.Empty)
            {
                <MudSelect T="Guid?" Label="Worker" @bind-Value="_selectedWorkerId" Variant="Variant.Outlined" Class="mb-2">
                    @foreach (var w in _workers)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)w.Id)">@w.Name</MudSelectItem>
                    }
                </MudSelect>
            }
            else
            {
                <MudText Class="mb-2">Worker: @GetWorkerName(_editingRate?.WorkerId)</MudText>
            }
            <MudNumericField T="decimal" Label="Rate Charged" @bind-Value="_formRateCharged" Min="0.01M" Variant="Variant.Outlined" Class="mb-2" />
            <MudNumericField T="decimal" Label="Rate Paid" @bind-Value="_formRatePaid" Min="0M" Variant="Variant.Outlined" Class="mb-2" />
            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveWorkerRateForm">Save</MudButton>
                <MudButton Variant="Variant.Text" OnClick="@(() => _showRateForm = false)">Cancel</MudButton>
            </MudStack>
        </MudPaper>
    }

    @if (_showLawnRateForm)
    {
        <MudPaper Class="pa-4 mt-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-2">@(_editingLawnRate?.Id != Guid.Empty ? "Edit" : "Add") Lawn Rate — @GetHouseName(_editingHouseId)</MudText>
            @if (_editingLawnRate?.Id == Guid.Empty)
            {
                <MudSelect T="Guid?" Label="Worker" @bind-Value="_selectedWorkerId" Variant="Variant.Outlined" Class="mb-2">
                    @foreach (var w in _workers)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)w.Id)">@w.Name</MudSelectItem>
                    }
                </MudSelect>
            }
            else
            {
                <MudText Class="mb-2">Worker: @GetWorkerName(_editingLawnRate?.WorkerId)</MudText>
            }
            <MudNumericField T="decimal" Label="Rate Charged" @bind-Value="_formRateCharged" Min="0.01M" Variant="Variant.Outlined" Class="mb-2" />
            <MudNumericField T="decimal" Label="Rate Paid" @bind-Value="_formRatePaid" Min="0M" Variant="Variant.Outlined" Class="mb-2" />
            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveWorkerLawnRateForm">Save</MudButton>
                <MudButton Variant="Variant.Text" OnClick="@(() => _showLawnRateForm = false)">Cancel</MudButton>
            </MudStack>
        </MudPaper>
    }
</RoleGuard>

@code {
    private List<Rate> _rates = new();
    private List<LawnHouseRate> _lawnRates = new();
    private List<Worker> _workers = new();
    private List<House> _houses = new();

    // Rate form state
    private bool _showRateForm;
    private Rate? _editingRate;
    private string _editingCategory = string.Empty;
    private decimal _formRateCharged;
    private decimal _formRatePaid;
    private Guid? _selectedWorkerId;

    // Lawn rate form state
    private bool _showLawnRateForm;
    private LawnHouseRate? _editingLawnRate;
    private Guid _editingHouseId;

    // Temporary state for default rate edits
    private Dictionary<string, (decimal Charged, decimal Paid)> _defaultRateEdits = new();
    private Dictionary<Guid, (decimal Charged, decimal Paid)> _defaultLawnRateEdits = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _workers = await WorkerService.GetActiveAsync();
        _houses = await HouseService.GetActiveAsync();

        var categories = new[] { "Cleaning", "Maintenance", "Laundry" };
        _rates = new List<Rate>();
        foreach (var cat in categories)
        {
            var catRates = await RateService.GetByCategoryAsync(cat);
            _rates.AddRange(catRates);
        }

        _lawnRates = await RateService.GetAllLawnRatesAsync();
        _defaultRateEdits.Clear();
        _defaultLawnRateEdits.Clear();
    }

    private Rate? GetDefaultRate(string category) =>
        _rates.FirstOrDefault(r => r.WorkCategoryValue == category && r.WorkerId == null);

    private List<Rate> GetWorkerRates(string category) =>
        _rates.Where(r => r.WorkCategoryValue == category && r.WorkerId != null).ToList();

    private LawnHouseRate? GetDefaultLawnRate(Guid houseId) =>
        _lawnRates.FirstOrDefault(r => r.HouseId == houseId && r.WorkerId == null);

    private List<LawnHouseRate> GetWorkerLawnRates(Guid houseId) =>
        _lawnRates.Where(r => r.HouseId == houseId && r.WorkerId != null).ToList();

    private string GetWorkerName(Guid? workerId) =>
        workerId.HasValue ? _workers.FirstOrDefault(w => w.Id == workerId.Value)?.Name ?? "Unknown" : "Default";

    private string GetHouseName(Guid houseId) =>
        _houses.FirstOrDefault(h => h.Id == houseId)?.Name ?? "Unknown";

    // --- Default rate inline editing ---

    private void OnDefaultRateChanged(string category, decimal charged, decimal paid)
    {
        _defaultRateEdits[category] = (charged, paid);
    }

    private async Task SaveDefaultRate(string category)
    {
        if (!_defaultRateEdits.TryGetValue(category, out var edits))
        {
            var existing = GetDefaultRate(category);
            if (existing == null) return;
            edits = (existing.RateCharged, existing.RatePaid);
        }

        if (edits.Charged <= 0)
        {
            Snackbar.Add("Rate charged must be greater than zero.", Severity.Error);
            return;
        }
        if (edits.Paid < 0)
        {
            Snackbar.Add("Rate paid cannot be negative.", Severity.Error);
            return;
        }

        var rate = GetDefaultRate(category) ?? new Rate { WorkCategoryValue = category, WorkerId = null };
        rate.RateCharged = edits.Charged;
        rate.RatePaid = edits.Paid;

        try
        {
            await RateService.CreateOrUpdateAsync(rate);
            Snackbar.Add($"{category} default rate saved.", Severity.Success);
            await LoadData();
        }
        catch (ArgumentException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private void OnDefaultLawnRateChanged(Guid houseId, decimal charged, decimal paid)
    {
        _defaultLawnRateEdits[houseId] = (charged, paid);
    }

    private async Task SaveDefaultLawnRate(Guid houseId)
    {
        if (!_defaultLawnRateEdits.TryGetValue(houseId, out var edits))
        {
            var existing = GetDefaultLawnRate(houseId);
            if (existing == null) return;
            edits = (existing.RateCharged, existing.RatePaid);
        }

        if (edits.Charged <= 0)
        {
            Snackbar.Add("Rate charged must be greater than zero.", Severity.Error);
            return;
        }
        if (edits.Paid < 0)
        {
            Snackbar.Add("Rate paid cannot be negative.", Severity.Error);
            return;
        }

        var rate = GetDefaultLawnRate(houseId) ?? new LawnHouseRate { HouseId = houseId, WorkerId = null };
        rate.RateCharged = edits.Charged;
        rate.RatePaid = edits.Paid;

        try
        {
            await RateService.CreateOrUpdateLawnRateAsync(rate);
            Snackbar.Add("Lawn default rate saved.", Severity.Success);
            await LoadData();
        }
        catch (ArgumentException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    // --- Worker rate form ---

    private void ShowAddWorkerRate(string category)
    {
        _editingRate = new Rate { WorkCategoryValue = category };
        _editingCategory = category;
        _formRateCharged = 0;
        _formRatePaid = 0;
        _selectedWorkerId = null;
        _showRateForm = true;
        _showLawnRateForm = false;
    }

    private void EditWorkerRate(Rate rate)
    {
        _editingRate = rate;
        _editingCategory = rate.WorkCategoryValue;
        _formRateCharged = rate.RateCharged;
        _formRatePaid = rate.RatePaid;
        _selectedWorkerId = rate.WorkerId;
        _showRateForm = true;
        _showLawnRateForm = false;
    }

    private async Task SaveWorkerRateForm()
    {
        if (_editingRate!.Id == Guid.Empty && _selectedWorkerId == null)
        {
            Snackbar.Add("Please select a worker.", Severity.Error);
            return;
        }
        if (_formRateCharged <= 0)
        {
            Snackbar.Add("Rate charged must be greater than zero.", Severity.Error);
            return;
        }
        if (_formRatePaid < 0)
        {
            Snackbar.Add("Rate paid cannot be negative.", Severity.Error);
            return;
        }

        _editingRate!.RateCharged = _formRateCharged;
        _editingRate.RatePaid = _formRatePaid;
        if (_editingRate.Id == Guid.Empty)
            _editingRate.WorkerId = _selectedWorkerId;

        try
        {
            await RateService.CreateOrUpdateAsync(_editingRate);
            Snackbar.Add("Worker rate saved.", Severity.Success);
            _showRateForm = false;
            await LoadData();
        }
        catch (ArgumentException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    // --- Worker lawn rate form ---

    private void ShowAddWorkerLawnRate(Guid houseId)
    {
        _editingLawnRate = new LawnHouseRate { HouseId = houseId };
        _editingHouseId = houseId;
        _formRateCharged = 0;
        _formRatePaid = 0;
        _selectedWorkerId = null;
        _showLawnRateForm = true;
        _showRateForm = false;
    }

    private void EditWorkerLawnRate(LawnHouseRate rate)
    {
        _editingLawnRate = rate;
        _editingHouseId = rate.HouseId;
        _formRateCharged = rate.RateCharged;
        _formRatePaid = rate.RatePaid;
        _selectedWorkerId = rate.WorkerId;
        _showLawnRateForm = true;
        _showRateForm = false;
    }

    private async Task SaveWorkerLawnRateForm()
    {
        if (_editingLawnRate!.Id == Guid.Empty && _selectedWorkerId == null)
        {
            Snackbar.Add("Please select a worker.", Severity.Error);
            return;
        }
        if (_formRateCharged <= 0)
        {
            Snackbar.Add("Rate charged must be greater than zero.", Severity.Error);
            return;
        }
        if (_formRatePaid < 0)
        {
            Snackbar.Add("Rate paid cannot be negative.", Severity.Error);
            return;
        }

        _editingLawnRate!.RateCharged = _formRateCharged;
        _editingLawnRate.RatePaid = _formRatePaid;
        if (_editingLawnRate.Id == Guid.Empty)
            _editingLawnRate.WorkerId = _selectedWorkerId;

        try
        {
            await RateService.CreateOrUpdateLawnRateAsync(_editingLawnRate);
            Snackbar.Add("Worker lawn rate saved.", Severity.Success);
            _showLawnRateForm = false;
            await LoadData();
        }
        catch (ArgumentException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
