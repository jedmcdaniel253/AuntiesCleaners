@page "/boss-profit"
@using AuntiesCleaners.Client.Models
@using AuntiesCleaners.Client.Services
@using AuntiesCleaners.Client.Shared
@inject IProfitReportService ProfitReportService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager

<RoleGuard AllowedRoles="@(new[] { Role.Boss, Role.Admin })">
    <MudText Typo="Typo.h5" Class="mb-4">Boss Profit Report</MudText>

    <MudPaper Class="pa-4 mb-4" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudDatePicker Label="From Date" @bind-Date="_fromDate" Variant="Variant.Outlined" Style="max-width:200px" />
            <MudDatePicker Label="To Date" @bind-Date="_toDate" Variant="Variant.Outlined" Style="max-width:200px" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GenerateReport" Disabled="_loading">
                @if (_loading) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Generate
            </MudButton>
        </MudStack>
    </MudPaper>

    @if (_report != null)
    {
        @if (_report.GrandTotal == 0 && _report.Categories.All(c => c.CategoryTotal == 0))
        {
            <MudAlert Severity="Severity.Info" Class="mb-4">No data found for the selected period.</MudAlert>
        }
        else
        {
            <MudSimpleTable Hover="true" Dense="true" Striped="true" Class="mb-4">
                <thead>
                    <tr>
                        <th>Category</th>
                        <th style="text-align:right">Boss Own Work</th>
                        <th style="text-align:right">Worker Margin</th>
                        <th style="text-align:right">Category Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var category in _report.Categories)
                    {
                        <tr>
                            <td>@category.CategoryName</td>
                            <td style="text-align:right">@category.BossOwnTotal.ToString("C2")</td>
                            <td style="text-align:right">@category.WorkerMarginTotal.ToString("C2")</td>
                            <td style="text-align:right">@category.CategoryTotal.ToString("C2")</td>
                        </tr>
                    }
                    <tr style="font-weight:bold">
                        <td>Grand Total</td>
                        <td></td>
                        <td></td>
                        <td style="text-align:right">@_report.GrandTotal.ToString("C2")</td>
                    </tr>
                </tbody>
            </MudSimpleTable>
        }
    }
</RoleGuard>

@code {
    private DateTime? _fromDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime? _toDate = DateTime.Today;
    private BossProfitReport? _report;
    private bool _loading;

    private async Task GenerateReport()
    {
        if (_fromDate == null || _toDate == null)
        {
            Snackbar.Add("Please select both From and To dates.", Severity.Warning);
            return;
        }

        if (_fromDate > _toDate)
        {
            Snackbar.Add("From date must be before To date.", Severity.Warning);
            return;
        }

        _loading = true;
        try
        {
            _report = await ProfitReportService.GenerateReportAsync(_fromDate.Value, _toDate.Value);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error generating report: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }
}
