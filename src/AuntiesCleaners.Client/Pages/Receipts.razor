@page "/receipts"
@using AuntiesCleaners.Client.Models
@using AuntiesCleaners.Client.Services
@using AuntiesCleaners.Client.Shared
@inject IReceiptService ReceiptService
@inject IAuthService AuthService
@inject IShareService ShareService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-4">
    <MudText Typo="Typo.h5" Class="mb-4">Receipts</MudText>

    <ReceiptForm OnSubmitted="OnReceiptSubmitted" />

    <MudDivider Class="my-4" />

    <MudText Typo="Typo.h6" Class="mb-2">Saved Receipts</MudText>

    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
        <MudDatePicker Label="From" Date="_dateFrom" DateChanged="OnDateFromChanged"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width: 160px;" />
        <MudDatePicker Label="To" Date="_dateTo" DateChanged="OnDateToChanged"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width: 160px;" />
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (!_receipts.Any())
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary">No receipts found.</MudText>
    }
    else
    {
        <MudTable Items="_receipts" Hover="true" Dense="true">
            <HeaderContent>
                <MudTh>Date</MudTh>
                <MudTh>Business</MudTh>
                <MudTh>Amount</MudTh>
                <MudTh>Type</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.ReceiptDate.ToString("MM/dd/yyyy")</MudTd>
                <MudTd>@context.BusinessName</MudTd>
                <MudTd>@context.Amount.ToString("C")</MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small"
                             Color="@(context.IsReimbursable ? Color.Success : Color.Default)">
                        @(context.IsReimbursable ? "Reimb." : "Non-reimb.")
                    </MudChip>
                </MudTd>
                <MudTd>
                    @if (!string.IsNullOrWhiteSpace(context.PhotoUrl))
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Receipt" Size="Size.Small"
                                       Color="Color.Primary" aria-label="View Receipt"
                                       OnClick="@(() => OpenPhoto(context.PhotoUrl))" />
                    }
                    <MudIconButton Icon="@Icons.Material.Filled.Share" Size="Size.Small"
                                   OnClick="@(() => ShareReceipt(context))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                   Color="Color.Error" OnClick="@(() => DeleteReceipt(context))" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudContainer>

@code {
    private List<Receipt> _receipts = new();
    private bool _loading = true;
    private DateTime? _dateFrom = DateTime.Today.AddDays(-30);
    private DateTime? _dateTo = DateTime.Today;

    protected override async Task OnInitializedAsync()
    {
        await LoadReceipts();
    }

    private async Task LoadReceipts()
    {
        _loading = true;
        try
        {
            var from = _dateFrom ?? DateTime.Today.AddDays(-30);
            var to = _dateTo ?? DateTime.Today;
            _receipts = await ReceiptService.GetByDateRangeAsync(from, to);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnDateFromChanged(DateTime? value)
    {
        _dateFrom = value;
        await LoadReceipts();
    }

    private async Task OnDateToChanged(DateTime? value)
    {
        _dateTo = value;
        await LoadReceipts();
    }

    private async Task OnReceiptSubmitted()
    {
        await LoadReceipts();
    }

    private async Task ShareReceipt(Receipt receipt)
    {
        var text = $"Receipt: {receipt.BusinessName} - {receipt.Amount:C} on {receipt.ReceiptDate:MM/dd/yyyy}";
        await ShareService.ShareTextAsync("Receipt", text);
    }

    private async Task OpenPhoto(string url)
    {
        await JS.InvokeVoidAsync("window.open", url, "_blank");
    }

    private async Task DeleteReceipt(Receipt receipt)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.ContentText, $"Delete receipt from {receipt.BusinessName}?" },
            { x => x.ButtonText, "Delete" },
            { x => x.Color, Color.Error }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Confirm Delete", parameters);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await ReceiptService.DeleteAsync(receipt.Id);
            Snackbar.Add("Receipt deleted", Severity.Success);
            await LoadReceipts();
        }
    }
}
