@inherits LayoutComponentBase
@using AuntiesCleaners.Client.Services
@using AuntiesCleaners.Client.Shared
@inject IAuthService AuthService
@inject NavigationManager Navigation

<MudThemeProvider Theme="_purpleTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@if (!_initialized)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (!AuthService.IsAuthenticated)
{
    @Body
}
else
{
    <MudLayout>
        <MudAppBar Elevation="1" Color="Color.Primary">
            <MudText Typo="Typo.h6">Auntie's Cleaners</MudText>
            <AppVersionDisplay />
            <MudSpacer />
            <MudIconButton Icon="@Icons.Material.Filled.Logout"
                           Color="Color.Inherit"
                           aria-label="Logout"
                           OnClick="HandleLogout" />
        </MudAppBar>

        <MudMainContent Class="pa-4 pb-16">
            @Body
        </MudMainContent>

        <BottomNavBar />
    </MudLayout>
}

@code {
    private MudTheme _purpleTheme = new MudTheme
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#6A1B9A",
            PrimaryDarken = "#4A148C",
            PrimaryLighten = "#9C27B0",
            AppbarBackground = "#6A1B9A",
            AppbarText = "#FFFFFF"
        }
    };

    private bool _initialized;

    protected override async Task OnInitializedAsync()
    {
        AuthService.OnAuthStateChanged += StateHasChanged;
        await AuthService.InitializeAsync();
        _initialized = true;
    }

    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateToRoute("login");
    }

    public void Dispose()
    {
        AuthService.OnAuthStateChanged -= StateHasChanged;
    }
}
